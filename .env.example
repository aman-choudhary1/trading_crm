# =============================================================================
# Mini Trading CRM Backend — Environment Variables Example
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to version control.
# =============================================================================

# ── Flask ────────────────────────────────────────────────────────────────────
# A long random secret key for Flask session signing.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-very-secret-key-change-me

# Development | Production | Testing
FLASK_ENV=development
FLASK_DEBUG=1

# ── Database (MySQL via PyMySQL) ──────────────────────────────────────────────
# Format: mysql+pymysql://user:password@host:port/dbname
SQLALCHEMY_DATABASE_URI=mysql+pymysql://root:password@localhost:3306/trading_crm

# ── API Authentication ────────────────────────────────────────────────────────
# Simple API key sent as X-API-Key header on all /api requests.
# NOTE: Replace this with proper JWT/OAuth2 in production!
API_KEY=change-me-super-secret-api-key

# ── Fernet Encryption (MT5 passwords) ────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-fernet-key-base64-here

# ── MetaTrader 5 Defaults ─────────────────────────────────────────────────────
# NOTE: MetaTrader5 package is Windows-only. See README for details.
MT5_DEFAULT_SERVER=MetaQuotes-Demo
MT5_TIMEOUT_MS=10000

# ── Commission Engine ─────────────────────────────────────────────────────────
# Rate in USD per standard lot traded.
COMMISSION_RATE_PER_LOT=5.00

# ── Scheduler ─────────────────────────────────────────────────────────────────
# How often (in seconds) the background sync job runs across all broker accounts.
SYNC_INTERVAL_SECONDS=60

# ── Copier Service ────────────────────────────────────────────────────────────
# How often (in seconds) the trade copier loop polls master positions.
COPIER_POLL_SECONDS=2
